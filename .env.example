APP_NAME="Loyalty Promotion Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
ADMIN_EMAILS=

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=loyalty_promotion
DB_USERNAME=loyalty_user
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

KAFKA_BROKERS=localhost:9092

IIKO_CLOUD_BASE_URL=https://api-ru.iiko.services/api
IIKO_API_LOGIN=
IIKO_CLOUD_CALL_CENTER_ORG_ID=84f0f1ff-1ba0-4857-bfc6-1ae23b0b4cb1
IIKO_SYNC_REQUEST_DELAY_SECONDS=4

LOYALTY_MAX_TOTAL_DISCOUNT_AMOUNT=80000
LOYALTY_MAX_BELLCOIN_REDEEM_PERCENT=100
LOYALTY_MAX_BELLCOIN_REDEEM_AMOUNT=80000
LOYALTY_BELLCOIN_ACCRUAL_PERCENT=2
LOYALTY_BELLCOIN_EXPIRATION_DAYS=365
LOYALTY_RESERVATION_TTL_MINUTES=5

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
